-- 🌟 كود زر الاختفاء الجديد (Invisibility) 🌟
local InvisibleBtn = Instance.new("TextButton", PlayerPage)
InvisibleBtn.Size = UDim2.new(0.9, 0, 0, 40)
InvisibleBtn.Text = "الاختفاء: مطفأ"
InvisibleBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
InvisibleBtn.TextColor3 = Color3.new(1, 1, 1)
Instance.new("UICorner", InvisibleBtn)

local IsInvisible = false
InvisibleBtn.MouseButton1Click:Connect(function()
    local Character = Player.Character
    if not Character then return end
    
    IsInvisible = not IsInvisible
    
    -- تغيير شفافية الأجزاء الأساسية للاعب والملابس والإكسسوارات
    for _, part in pairs(Character:GetDescendants()) do
        if part:IsA("BasePart") or part:IsA("Decal") then
            if IsInvisible then
                -- حفظ الشفافية الأصلية ليرجع الحجم الطبيعي عند الإطفاء
                if not part:FindFirstChild("OriginalTransparency") then
                    local originalValue = Instance.new("NumberValue", part)
                    originalValue.Name = "OriginalTransparency"
                    originalValue.Value = part.Transparency
                end
                part.Transparency = 1
            else
                local originalValue = part:FindFirstChild("OriginalTransparency")
                part.Transparency = originalValue and originalValue.Value or 0
            end
        end
    end
    
    -- التعامل مع اسم اللاعب فوق رأسه (لو كان موجود)
    local Head = Character:FindFirstChild("Head")
    if Head then
        local humanoidRootPart = Character:FindFirstChild("HumanoidRootPart")
        if Character:FindFirstChildOfClass("Humanoid") then
            Character:FindFirstChildOfClass("Humanoid").DisplayDistanceType = IsInvisible and Enum.HumanoidDisplayDistanceType.None or Enum.HumanoidDisplayDistanceType.Viewer
        end
    end

    InvisibleBtn.Text = IsInvisible and "الاختفاء: شغال" or "الاختفاء: مطفأ"
    InvisibleBtn.BackgroundColor3 = IsInvisible and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
end)
